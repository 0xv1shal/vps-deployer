extends ../../dashboard/views/layout.pug

block content
  // Page Header
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.mb-1 Project Details
      p.text-muted.mb-0 Manage your project configuration and deployment
    div
      a.btn.btn-outline-secondary(href="/projects")
        i.bi.bi-arrow-left.me-2
        | Back to Projects

  .row
    .col-lg-6.mb-4
      // ================= PROJECT INFO & WEBHOOK =================
      .card.border-0.shadow-sm.mb-4
        .card-header.bg-white.border-bottom-0.pt-3
          .d-flex.align-items-center
            i.bi.bi-info-circle.text-primary.me-2(style="font-size: 1.25rem;")
            h5.mb-0 Project Information
        .card-body
          // Webhook Info
          .alert.alert-info.mb-4
            .mb-3
              strong
                i.bi.bi-link.me-1
                | Webhook URL:
              br
              code.text-small #{`/webhook/${project.id}`}
            .mb-3
              strong
                i.bi.bi-key.me-1
                | Secret:
              br
              code.text-small #{project.webhook_secret}
            hr.mb-0
            .d-flex.justify-content-center.pt-2
              button.btn.btn-primary.w-100(
                id="deploy-btn",
                data-projid=project.id
              )
                i.bi.bi-rocket-takeoff.me-2
                | Deploy Now
          
          // Update Form
          form(method="POST", action=`/projects/${project.id}/update`)
            .mb-3
              label.form-label.fw-semibold(for="name")
                i.bi.bi-tag.me-1
                | Project Name
              input.form-control(
                type="text",
                id="name",
                name="name",
                value=project.name,
                required
              )
            
            .mb-3
              label.form-label.fw-semibold(for="github_url")
                i.bi.bi-github.me-1
                | GitHub URL
              input.form-control(
                type="text",
                id="github_url",
                name="github_url",
                value=project.github_url,
                required
              )
            
            .mb-3
              label.form-label.fw-semibold(for="branch_name")
                i.bi.bi-git-branch.me-1
                | Branch
              input.form-control(
                type="text",
                id="branch_name",
                name="branch_name",
                value=project.branch_name,
                required
              )
            
            .mb-3
              .form-check.mb-2
                input.form-check-input(
                  type="checkbox",
                  name="receive_email_notf",
                  id="receive_email_notf",
                  checked=(project.receive_email_notf === 1)
                )
                label.form-check-label.fw-semibold(for="receive_email_notf")
                  i.bi.bi-envelope.me-1
                  | Receive Email Notifications
              
              .form-check
                input.form-check-input(
                  type="checkbox",
                  name="auto_deploy",
                  id="auto_deploy",
                  checked=(project.auto_deploy === 1)
                )
                label.form-check-label.fw-semibold(for="auto_deploy")
                  i.bi.bi-rocket.me-1
                  | Enable Auto Deploy
            
            hr.my-4
            
            .d-flex.gap-2
              button.btn.btn-primary(type="submit")
                i.bi.bi-save.me-2
                | Update Project

    .col-lg-6.mb-4
      // ================= ENVIRONMENT VARIABLES =================
      .card.border-0.shadow-sm.mb-4
        .card-header.bg-white.border-bottom-0.pt-3
          .d-flex.align-items-center
            i.bi.bi-gear.text-primary.me-2(style="font-size: 1.25rem;")
            h5.mb-0 Environment Variables
        .card-body
          form(method="POST", action=`/projects/${project.id}/env`)
            .row.g-2.mb-3
              .col-md-5
                input.form-control(type="text", name="key", placeholder="KEY", required)
              .col-md-5
                input.form-control(type="text", name="value", placeholder="VALUE", required)
              .col-md-2
                button.btn.btn-primary.w-100(type="submit")
                  i.bi.bi-plus-lg
          
          if envs.length === 0
            .text-center.py-4
              i.bi.bi-database.text-muted(style="font-size: 2rem;")
              p.text-muted.mt-2.mb-0 No environment variables
          else
            .table-responsive
              table.table.table-hover.align-middle.mb-0
                thead.table-light
                  tr
                    th(style="font-weight: 600;") Key
                    th(style="font-weight: 600;") Value
                    th(style="width: 80px;") Action
                tbody
                  each e in envs
                    tr
                      td
                        code.text-small #{e.key}
                      td
                        code.text-small #{e.value}
                      td
                        form(method="POST", action=`/projects/${project.id}/env/${e.id}/delete`, onsubmit="return confirm('Delete this environment variable?');")
                          button.btn.btn-sm.btn-outline-danger(type="submit")
                            i.bi.bi-trash

      // ================= COMMANDS =================
      .card.border-0.shadow-sm
        .card-header.bg-white.border-bottom-0.pt-3
          .d-flex.align-items-center
            i.bi.bi-terminal.text-primary.me-2(style="font-size: 1.25rem;")
            h5.mb-0 Deployment Commands
        .card-body
          form(method="POST", action=`/projects/${project.id}/commands`)
            .input-group.mb-3
              input.form-control(type="text", name="cmd", placeholder="npm install", required)
              button.btn.btn-primary(type="submit")
                i.bi.bi-plus-lg.me-1
                | Add Command
          
          if commands.length === 0
            .text-center.py-4
              i.bi.bi-terminal-x.text-muted(style="font-size: 2rem;")
              p.text-muted.mt-2.mb-0 No deployment commands
          else
            .table-responsive
              table.table.table-hover.align-middle.mb-0
                thead.table-light
                  tr
                    th(style="width: 80px; font-weight: 600;") Seq
                    th(style="font-weight: 600;") Command
                    th(style="width: 80px;") Action
                tbody
                  each c in commands
                    tr
                      td
                        span.badge.bg-secondary #{c.seq_no}
                      td
                        code.text-small #{c.cmd}
                      td
                        form(method="POST", action=`/projects/${project.id}/commands/${c.id}/delete`, onsubmit="return confirm('Delete this command?');")
                          button.btn.btn-sm.btn-outline-danger(type="submit")
                            i.bi.bi-trash

  // Additional styles
  style.
    .card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
    
    .form-control:focus {
      border-color: #0066ff;
      box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
    }
    
    .alert-info {
      background: #e8f4ff;
      border: none;
      border-left: 4px solid #0066ff;
      color: #0047b3;
    }
    
    code {
      background: #f8f9fa;
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.8rem;
      color: #d63384;
    }
    
    .table-hover tbody tr:hover {
      background-color: #f8f9fa;
    }
    
    .btn-sm {
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
    }
    
    .badge {
      font-weight: 500;
    }

  script(src="/js/deploy.js")