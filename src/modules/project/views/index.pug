extends ../../dashboard/views/layout.pug

block content
  // Page Header
  .d-flex.flex-column.flex-md-row.justify-content-between.align-items-md-center.mb-4
    div
      h2.mb-1 Projects
      p.text-muted.mb-0 Manage and monitor your deployed projects
    div
      a.btn.btn-primary(href="/projects/create")
        i.bi.bi-plus-lg.me-2
        | Create Project

  // Empty State
  if projects.length === 0
    .card.border-0.shadow-sm
      .card-body.text-center.py-5
        i.bi.bi-folder-x.display-1.text-muted
        h4.mt-3.text-muted No projects yet
        p.text-muted.mb-3 Get started by creating your first project
        a.btn.btn-primary(href="/projects/create")
          i.bi.bi-plus-lg.me-2
          | Create Your First Project

  else
    // Projects Table
    .card.border-0.shadow-sm
      .card-header.bg-white.border-bottom-0.pt-3.pb-0
        .d-flex.align-items-center
          i.bi.bi-folder.text-primary.me-2(style="font-size: 1.25rem;")
          h5.mb-0 All Projects
      .card-body.p-0
        .table-responsive
          table.table.table-hover.align-middle.mb-0
            thead.table-light
              tr
                th(style="font-weight: 600;") Project Name
                th(style="font-weight: 600;") Repository
                th(style="font-weight: 600; width: 120px;") Actions
            tbody
              each p in projects
                tr
                  td
                    .d-flex.align-items-center
                      i.bi.bi-folder-fill.text-primary.me-2
                      span.fw-medium #{p.name}
                  td
                    .d-flex.align-items-center
                      i.bi.bi-github.me-2.text-muted
                      code.text-small #{p.github_url}
                  td
                    .d-flex.gap-2
                      a.btn.btn-sm.btn-outline-primary(href=`/projects/${p.id}`)
                        i.bi.bi-eye.me-1
                        | View
                      form.d-inline(method="POST", action=`/projects/${p.id}/delete`, onsubmit="return confirm('Are you sure you want to delete this project? This action cannot be undone.');")
                        button.btn.btn-sm.btn-outline-danger(type="submit")
                          i.bi.bi-trash.me-1
                          | Delete

  // Additional styles
  style.
    .card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
    
    .table-hover tbody tr:hover {
      background-color: #f8f9fa;
    }
    
    .btn-sm {
      padding: 0.375rem 0.75rem;
      font-size: 0.813rem;
    }
    
    code {
      background: #f8f9fa;
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.8rem;
      color: #d63384;
    }
    
    .table-responsive {
      border-radius: 8px;
      overflow: hidden;
    }
    
    .btn-outline-primary {
      border-color: #dee2e6;
      color: #0066ff;
    }
    
    .btn-outline-primary:hover {
      background: #0066ff;
      border-color: #0066ff;
      color: #ffffff;
    }
    
    .btn-outline-danger {
      border-color: #dee2e6;
      color: #dc3545;
    }
    
    .btn-outline-danger:hover {
      background: #dc3545;
      border-color: #dc3545;
      color: #ffffff;
    }