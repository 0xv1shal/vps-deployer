extends ../../dashboard/views/layout.pug
block content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.mb-1 Settings
      p.text-muted.mb-0 Manage your account and system configuration
    div
      i.bi.bi-gear.text-muted(style="font-size: 1.5rem;")
  if error
    .alert.alert-danger.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-exclamation-triangle-fill.me-2
      span.flex-grow-1 #{error}
  if success
    .alert.alert-success.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-check-circle-fill.me-2
      span.flex-grow-1 #{success}
  .row.mb-4
    .col-lg-4.mb-3
      .card.border-0.shadow-sm.h-100
        .card-header.bg-white.border-bottom-0.pt-3
          .d-flex.align-items-center
            i.bi.bi-person-circle.text-primary.me-2(style="font-size: 1.25rem;")
            h5.mb-0 User Details
        .card-body
          .mb-3.pb-2.border-bottom
            .d-flex.justify-content-between
              small.text-muted Username
              strong.text-dark #{user.username}
          .mb-3.pb-2.border-bottom
            .d-flex.justify-content-between
              small.text-muted Email
              strong.text-dark #{user.email}
          .mb-3.pb-2.border-bottom
            .d-flex.justify-content-between
              small.text-muted Created At
              strong.text-dark #{convertDateToIST(user.created_at)}
          .mb-3
            .d-flex.justify-content-between
              small.text-muted Last Logged In
              strong.text-dark #{convertDateToIST(user.last_logged_in)}
  .row
    .col-md-6.mb-4
      a.text-decoration-none(href="/settings/email")
        .card.border-0.shadow-sm.h-100.settings-card
          .card-body.d-flex.align-items-center
            .me-4
              .icon-circle.bg-primary.bg-opacity-10
                i.bi.bi-envelope.text-primary(style="font-size: 1.75rem;")
            div
              h5.mb-1.text-dark Email Settings
              p.mb-0.text-muted Configure SMTP and notification settings
              if email.smtp
                small.text-success
                  i.bi.bi-check-circle.me-1
                  | Configured
    .col-md-6.mb-4
      a.text-decoration-none(href="/settings/path")
        .card.border-0.shadow-sm.h-100.settings-card
          .card-body.d-flex.align-items-center
            .me-4
              .icon-circle.bg-success.bg-opacity-10
                i.bi.bi-folder2-open.text-success(style="font-size: 1.75rem;")
            div
              h5.mb-1.text-dark Path Settings
              p.mb-0.text-muted Configure system PATH for command execution
              if paths.length > 0
                small.text-success
                  i.bi.bi-check-circle.me-1
                  | #{paths.length} path(s) configured
  style.
    .settings-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: pointer;
    }
    
    .settings-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
    }
    
    .icon-circle {
      width: 60px;
      height: 60px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
    
    .alert {
      border-radius: 8px;
      border: none;
    }
    
    .alert-danger {
      background: #fff5f5;
      color: #c62828;
      border-left: 4px solid #c62828;
    }
    
    .alert-success {
      background: #f0f9f0;
      color: #2e7d32;
      border-left: 4px solid #2e7d32;
    }