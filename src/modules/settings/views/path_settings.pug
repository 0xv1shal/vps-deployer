extends ../../dashboard/views/layout.pug
block content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.mb-1 Path Settings
      p.text-muted.mb-0 Configure system PATH for command execution
    div
      i.bi.bi-folder2-open.text-muted(style="font-size: 1.5rem;")
    div
      a.btn.btn-outline-secondary.btn-sm(href="/settings")
        i.bi.bi-arrow-left.me-1
        | Back to Settings
  if error
    .alert.alert-danger.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-exclamation-triangle-fill.me-2
      span.flex-grow-1 #{error}
  if success
    .alert.alert-success.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-check-circle-fill.me-2
      span.flex-grow-1 #{success}
  .card.border-0.shadow-sm.mb-4
    .card-header.bg-white.border-bottom-0.pt-3
      .d-flex.align-items-center
        i.bi.bi-plus-circle.text-primary.me-2(style="font-size: 1.25rem;")
        h5.mb-0 Add New Path
    .card-body
      form(method="POST", action="/settings/path")
        .row.align-items-end
          .col
            label.form-label.fw-semibold(for="path-input")
              i.bi.bi-folder.me-1
              | Path
            input.form-control(
              type="text",
              id="path-input",
              name="path",
              placeholder="/home/user/.nvm/versions/node/v24.14.0/bin"
            )
          .col-auto
            button.btn.btn-primary(type="submit")
              i.bi.bi-plus-lg.me-2
              | Add
  .card.border-0.shadow-sm
    .card-header.bg-white.border-bottom-0.pt-3
      .d-flex.align-items-center
        i.bi.bi-list-ul.text-primary.me-2(style="font-size: 1.25rem;")
        h5.mb-0 Configured Paths
        span.badge.bg-secondary.ms-2 #{paths.length}
    .card-body.p-0
      if paths.length === 0
        .text-center.py-5.text-muted
          i.bi.bi-inbox(style="font-size: 3rem;")
          p.mt-2.mb-0 No paths configured. Add a path above.
      else
        .table-responsive
          table.table.table-hover.mb-0
            thead.bg-light
              tr
                th.text-nowrap.px-4 Seq
                th Path
                th.text-end.px-4 Actions
            tbody
              each p in paths
                tr
                  td.text-nowrap.px-4
                    span.badge.bg-light.text-dark ##{p.sequence + 1}
                  td.px-3
                    code.text-dark #{p.path}
                  td.text-end.px-4
                    .btn-group.btn-group-sm
                      button.btn.btn-outline-primary.edit-btn(
                        type="button",
                        data-id=p.id,
                        data-path=p.path
                      )
                        i.bi.bi-pencil
                      form.d-inline(
                        method="POST",
                        action="/settings/path/delete/" + p.id
                      )
                        button.btn.btn-outline-danger(type="submit")
                          i.bi.bi-trash
  #editModal.modal.fade(tabindex="-1")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title Edit Path
          button.btn-close(type="button", data-bs-dismiss="modal")
        form(method="POST", action="/settings/path/update")
          .modal-body
            input(type="hidden", name="id", id="edit-id")
            .mb-3
              label.form-label.fw-semibold(for="edit-path")
                i.bi.bi-folder.me-1
                | Path
              input.form-control(
                type="text",
                id="edit-path",
                name="path"
              )
          .modal-footer
            button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cancel
            button.btn.btn-primary(type="submit") Save Changes
  script.
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('edit-id').value = btn.dataset.id;
        document.getElementById('edit-path').value = btn.dataset.path;
        new bootstrap.Modal(document.getElementById('editModal')).show();
      });
    });
  style.
    .table > thead > tr > th {
      border-bottom: 2px solid #e9ecef;
      font-weight: 600;
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #6c757d;
    }
    
    .table > tbody > tr > td {
      vertical-align: middle;
    }
    
    code {
      background: #f8f9fa;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.875rem;
    }
    
    .btn-group-sm > .btn {
      padding: 0.25rem 0.5rem;
    }
    
    .card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
    
    .alert {
      border-radius: 8px;
      border: none;
    }
    
    .alert-danger {
      background: #fff5f5;
      color: #c62828;
      border-left: 4px solid #c62828;
    }
    
    .alert-success {
      background: #f0f9f0;
      color: #2e7d32;
      border-left: 4px solid #2e7d32;
    }