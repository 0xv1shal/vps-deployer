extends ../../dashboard/views/layout.pug
block content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.mb-1 Email Settings
      p.text-muted.mb-0 Configure SMTP for deployment notifications
    div
      i.bi.bi-envelope-gear.text-muted(style="font-size: 1.5rem;")
    div
      a.btn.btn-outline-secondary.btn-sm(href="/settings")
        i.bi.bi-arrow-left.me-1
        | Back to Settings
  if error
    .alert.alert-danger.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-exclamation-triangle-fill.me-2
      span.flex-grow-1 #{error}
  if success
    .alert.alert-success.alert-dismissible.fade-show.d-flex.align-items-center.mb-4(role="alert")
      i.bi.bi-check-circle-fill.me-2
      span.flex-grow-1 #{success}
  .row.mb-4
    .col-lg-12
      .card.border-0.shadow-sm
        .card-header.bg-white.border-bottom-0.pt-3
          .d-flex.align-items-center
            i.bi.bi-envelope-paper.text-primary.me-2(style="font-size: 1.25rem;")
            h5.mb-0 Email Actions
        .card-body
          form(method="POST", action="/settings/email/test")
            button.btn.btn-outline-success(type="submit")
              i.bi.bi-send.me-2
              | Send Test Email
  .card.border-0.shadow-sm
    .card-header.bg-white.border-bottom-0.pt-3
      .d-flex.align-items-center
        i.bi.bi-gear.text-primary.me-2(style="font-size: 1.25rem;")
        h5.mb-0 SMTP Configuration
    .card-body
      form(method="POST", action="/settings/email")
        .row
          .col-md-6.mb-3
            label.form-label.fw-semibold(for="email-username")
              i.bi.bi-person.me-1
              | Username
            input.form-control(
              type="text",
              id="email-username",
              name="username",
              value=email.username,
              placeholder="smtp username"
            )
          
          .col-md-6.mb-3
            label.form-label.fw-semibold(for="email-password")
              i.bi.bi-lock.me-1
              | Password
            input.form-control(
              type="password",
              id="email-password",
              name="password",
              value=email.password,
              placeholder="••••••••"
            )
        
        .row
          .col-md-6.mb-3
            label.form-label.fw-semibold(for="email-smtp")
              i.bi.bi-server.me-1
              | SMTP Host
            input.form-control(
              type="text",
              id="email-smtp",
              name="smtp",
              value=email.smtp,
              placeholder="smtp.gmail.com"
            )
          
          .col-md-6.mb-3
            label.form-label.fw-semibold(for="email-port")
              i.bi.bi-plug.me-1
              | SMTP Port
            input.form-control(
              type="number",
              id="email-port",
              name="smtp_port",
              value=email.smtp_port,
              placeholder="587"
            )
        
        .mb-3
          label.form-label.fw-semibold(for="email-from")
            i.bi.bi-envelope.me-1
            | From Email
          input.form-control(
            type="text",
            id="email-from",
            name="from",
            value=email.from,
            placeholder="noreply@example.com"
          )
        
        hr.my-4
        
        .d-flex.justify-content-end
          button.btn.btn-primary(type="submit")
            i.bi.bi-save.me-2
            | Save Configuration
  style.
    .card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
    
    .form-control:focus {
      border-color: #0066ff;
      box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
    }
    
    .alert {
      border-radius: 8px;
      border: none;
    }
    
    .alert-danger {
      background: #fff5f5;
      color: #c62828;
      border-left: 4px solid #c62828;
    }
    
    .alert-success {
      background: #f0f9f0;
      color: #2e7d32;
      border-left: 4px solid #2e7d32;
    }