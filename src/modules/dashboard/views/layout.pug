doctype html
html
  head
    title VPS Deployer
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css",
      rel="stylesheet"
    )
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="icon", type="image/svg+xml", href="/favicon.svg")
    
    style.
      body {
        background: #f5f7fa;
      }
      
      .navbar {
        background: #1a1f36 !important;
        border-bottom: 1px solid #e9ecef;
      }
      
      .navbar-brand {
        font-weight: 600;
        color: #ffffff !important;
      }
      
      .nav-link {
        color: #e0e0e0 !important;
      }
      
      .nav-link:hover {
        color: #ffffff !important;
      }
      
      .nav-link.active {
        color: #ffffff !important;
        font-weight: 500;
      }
      
      footer {
        background: #ffffff;
        border-top: 1px solid #e9ecef;
        color: #6c757d;
        font-size: 0.875rem;
      }
      
      .footer-link {
        color: #0066ff;
        text-decoration: none;
      }
      
      .footer-link:hover {
        text-decoration: underline;
      }

  body.d-flex.flex-column.min-vh-100

    // Navbar
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/")
          i.bi.bi-cloud-check.me-2
          | VPS Deployer

        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#nav")
          span.navbar-toggler-icon

        .collapse.navbar-collapse#nav
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(class=(active === "home" ? "active" : ""), href="/") Home
            li.nav-item
              a.nav-link(class=(active === "project" ? "active" : ""), href="/projects") Projects
            li.nav-item
              a.nav-link(class=(active === "deployments" ? "active" : ""), href="/deployments") Deployments
            li.nav-item
              a.nav-link(class=(active === "settings" || active === "path_settings" ? "active" : ""), href="/settings") Settings

    // Main content
    main.container.my-4.flex-grow-1
      block content

    // Footer
    footer.text-center.py-3.mt-auto
      .container
        span Made with 
        i.bi.bi-suit-heart-fill.text-danger
        |  for the OSS community by 
        a.footer-link(href="https://github.com/0xv1shal", target="_blank") 0xv1shal

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")